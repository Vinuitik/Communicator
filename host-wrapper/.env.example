# host-wrapper/.env — this service's own SSOT (unlike OO, Communicator has no
# repo-root .env; each service keeps its own, same convention as ai_agent/.env).
# Copy this file to .env and fill in whichever provider keys you have — any
# provider without a key is skipped by the router, no error.

# PORT=5011
# NOTE: intentionally NOT 5001 — ObsidianOptimizer's own host-wrapper (a sister
# project that may run on the same machine) defaults to 5001. Pick a port that
# doesn't collide if both run at once.

GEMINI_API_KEY=
GITHUB_MODELS_TOKEN=
MISTRAL_API_KEY=
GROQ_API_KEY=
# DEEPSEEK_API_KEY=
# ANTHROPIC_API_KEY=

# Provider order (comma-separated). Defaults match llm_router.py.
# LLM_TEXT_PRIORITY=groq,github,mistral,deepseek,gemini,claude-cli
# LLM_VISION_PRIORITY=gemini,github,mistral,anthropic

# LLM_REQUEST_TIMEOUT_S=120
# LLM_ACQUIRE_DEADLINE_S=150
# LLM_TEXT_MAX_TOKENS=4096
# LLM_VISION_MAX_TOKENS=1024
# CLI_TIMEOUT_S=180

# Global ignore patterns for the entire Communicator project

# IDE and Editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
.claude

# OS generated files
*.log
*.tmp
*.temp

# Backup files
*.bak
*.backup
*~

# Environment files (global)
.env
.env.local
.env.*.local

# Service account keys and secrets
backup/service-account-key.json
ai_agent/.env
ai_agent/service-account-key.json
**/service-account-key.json
**/*.key
**/*.pem
**/secrets.json

# Cache directories
.cache/
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd
.Python

# Build directories
**/build/
**/dist/
**/*.egg-info/
**/target/
**/*.class

# Node modules (if any JavaScript projects)
**/node_modules/

# Resource files (as you already have)
resourceRepository/photos/**
resourceRepository/videos/**
resourceRepository/voice/**
resourceRepository/personalResources/**

# Log files
**/*.log
**/logs/

# Graphify (keep final outputs, ignore intermediates)
.graphify_python
.graphify_*.json
.graphify_*.txt
.graphify_incremental.json
.graphify_old.json

# Ignore any accidental graphify output directories inside source trees.
# Keep only the canonical committable outputs under graphify-runs/**/graphify-out/.
**/graphify-out/**
!graphify-runs/**/graphify-out/
!graphify-runs/**/graphify-out/**

# Chunk scratch files (generated during semantic extraction)
**/graphify-out/.graphify_chunk_*.json
**/graphify-out/.needs_update

# Recommended run output location (committable): graphify-runs/**/graphify-out/
# (Do not ignore graphify-runs itself; only ignore temp files within it.)
graphify-runs/**/.graphify_*.json
graphify-runs/**/.graphify_*.txt
graphify-runs/**/graphify-out/.graphify_chunk_*.json
graphify-runs/**/graphify-out/.needs_update
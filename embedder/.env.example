# embedder/.env — this service's own SSOT (same convention as ai_agent/.env
# and host-wrapper/.env). Copy this file to .env and adjust if needed; every
# value below has a working default baked into model_runtime.py.

# EMBED_MODEL=onnx-community/embeddinggemma-300m-ONNX
# EMBED_ONNX_FILE=onnx/model_quantized.onnx
# MODEL_CACHE=/models
# EMBED_BATCH_SIZE=16
# EMBED_ORT_OPT=basic

# Prompt prefixes — only override if swapping to a different asymmetric model.
# EMBED_QUERY_PREFIX=task: search result | query:
# EMBED_DOC_PREFIX=title: none | text:

# Communicator environment — copy to .env and fill in.
# docker-compose reads this file automatically for ${VAR} substitution.

# ── Host ──────────────────────────────────────────────────────────────────────
# Auto-detected by run-compose.sh; overrides the container clock. e.g. Europe/London
HOST_TIMEZONE=UTC

# ── AI keys (ai-agent) ────────────────────────────────────────────────────────
GEMINI_API_KEY=
HUGGINGFACE_API_KEY=

# ── Backup service — Google Drive (OAuth) ─────────────────────────────────────
# Single-tenant: the OWNER connects their own Google account ONCE via the browser.
# These come from a Google Cloud Console → OAuth 2.0 Client (Web application), scope
# .../auth/drive.file. (The values in .env are copied from the ObsidianOptimizer
# client — Communicator reuses the same Cloud project.)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# MUST be added verbatim to that OAuth client's "Authorized redirect URIs" in
# Google Cloud Console, or the consent callback 400s. Local default:
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8090/backup/oauth/callback

# AES-256-GCM passphrase for encrypting backups before upload (PBKDF2, same scheme
# + salt as ObsidianOptimizer). Blank = encryption disabled and backups are refused.
# Keep this safe: lose it and the Drive backups are unrecoverable.
SYNC_PASSPHRASE=

# Retention: keep this many of each kind (db / files); older are hard-deleted from Drive.
BACKUP_KEEP=3
# Nightly auto-backup schedule (Spring cron: sec min hour dom mon dow, UTC).
BACKUP_CRON=0 0 3 * * *

# ── One-time setup ────────────────────────────────────────────────────────────
# 1. Add GOOGLE_OAUTH_REDIRECT_URI (above) to the OAuth client's redirect URIs.
# 2. docker compose up -d
# 3. Open http://localhost:8090/backup/oauth/url in a browser → consent once.
# 4. Verify: curl http://localhost:8090/backup/status
